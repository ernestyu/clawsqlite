#!/usr/bin/env bash
# Legacy compatibility wrapper for the old `clawkb` entrypoint.
#
# New usage should prefer:
#   ./bin/clawsqlite knowledge ...
#
# This script exists so older docs/skills that still call `./bin/clawkb`
# do not break immediately. It simply forwards to the new CLI.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR%/bin}"
cd "$REPO_ROOT"

# Reuse the same Python selection convention, but call clawsqlite instead.
PYTHON_BIN="${CLAWSQLITE_PYTHON:-${CLAWKB_PYTHON:-python3}}"
exec "$PYTHON_BIN" -m clawsqlite_cli knowledge "$@"
