#!/usr/bin/env bash
# Top-level entrypoint for clawsqlite CLI.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR%/bin}"
cd "$REPO_ROOT"

# Ensure Python can import the local packages
if [[ -z "${PYTHONPATH-}" ]]; then
  export PYTHONPATH="$REPO_ROOT"
else
  export PYTHONPATH="$REPO_ROOT:$PYTHONPATH"
fi

PYTHON_BIN="${CLAWSQLITE_PYTHON:-python3}"
exec "$PYTHON_BIN" -m clawsqlite_cli "$@"
