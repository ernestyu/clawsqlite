{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClawSQLite Knowledge Skill Request",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["ingest_url", "ingest_text", "search", "show", "doctor"]
    },
    "config": {
      "type": "string",
      "description": "Path to clawsqlite.toml. Prefer absolute paths. If omitted, CLAWSQLITE_CONFIG must be set."
    },
    "allow_heuristic": {
      "type": "boolean",
      "default": false
    },
    "allow_missing_embedding": {
      "type": "boolean",
      "default": false
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "default": 600
    },
    "url": {"type": "string"},
    "text": {"type": "string"},
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "tags": {"type": "string"},
    "category": {"type": "string"},
    "priority": {"type": "integer"},
    "update_existing": {"type": "boolean", "default": false},
    "gen_provider": {
      "type": "string",
      "enum": ["openclaw", "llm", "off"]
    },
    "query": {"type": "string"},
    "mode": {
      "type": "string",
      "enum": ["hybrid", "fts", "vec"]
    },
    "topk": {"type": "integer", "minimum": 1},
    "candidates": {"type": "integer", "minimum": 1},
    "llm_keywords": {
      "type": "string",
      "enum": ["auto", "on", "off"]
    },
    "tag": {"type": "string"},
    "since": {"type": "string"},
    "include_deleted": {"type": "boolean", "default": false},
    "explain": {"type": "boolean", "default": false},
    "id": {"type": ["integer", "string"]},
    "full": {"type": "boolean", "default": false},
    "check_embedding": {"type": "boolean", "default": false}
  },
  "additionalProperties": false
}
