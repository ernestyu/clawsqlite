# Clawsqlite knowledge project-level environment example
# Copy this file to `.env` and fill in the secrets for your environment.

# --- Embedding service (required for vector search) ---
# Base URL of the embedding API (OpenAI-compatible)
EMBEDDING_BASE_URL=https://embed.example.com/v1

# Embedding model name used for this knowledge base
EMBEDDING_MODEL=your-embedding-model-name

# API key for the embedding provider (keep this secret; do NOT commit your real key)
EMBEDDING_API_KEY=sk-your-embedding-key

# Vector dimension for this embedding model.
# You can obtain this by calling the embedding API once and checking len(embedding).
# Example: 1024 for BAAI/bge-m3 in our reference setup.
CLAWSQLITE_VEC_DIM=1024

# --- Optional: small LLM for keyword expansion / summaries ---
SMALL_LLM_BASE_URL=https://llm.example.com/v1
SMALL_LLM_MODEL=your-small-llm-name
SMALL_LLM_API_KEY=sk-your-small-llm-key

# --- Optional: FTS jieba fallback (CJK) ---
# auto (default): enable when libsimple tokenizer is unavailable and jieba is installed
# CLAWSQLITE_FTS_JIEBA=auto

# --- Optional: search score weights ---
# Default weights are:
#   0.55 for vector similarity
#   0.25 for FTS (BM25) score
#   0.15 for tag match score
#   0.03 for priority bonus
#   0.02 for recency bonus
# You can override them by setting all five keys in one string, e.g.:
# CLAWSQLITE_SCORE_WEIGHTS=vec=0.55,fts=0.25,tag=0.15,priority=0.03,recency=0.02

# --- Root override (optional) ---
# If not set, clawsqlite knowledge defaults to <cwd>/knowledge_data
# CLAWSQLITE_ROOT=/path/to/knowledge_root
# CLAWSQLITE_DB=/path/to/knowledge.sqlite3
# CLAWSQLITE_ARTICLES_DIR=/path/to/articles

# --- Interest clustering (optional) ---
# CLAWSQLITE_INTEREST_MERGE_DISTANCE controls how aggressively we merge
# nearby interest clusters whose centroids are close in the embedding
# space. The value is interpreted as a cosine distance (1 - cos sim)
# threshold between cluster centroids:
#
#   - smaller values  (~0.05–0.07) → finer-grained topics, more clusters
#   - larger values   (~0.08–0.12) → coarser topics, fewer clusters
#
# If unset, build_interest_clusters will fall back to an internal default
# (currently 0.06). For a typical KB, values around 0.07 have produced
# balanced cluster sizes with clear separation between topics.
#
# You can also steer automatic suggestions via
# CLAWSQLITE_INTEREST_MERGE_ALPHA: this multiplier is applied to the
# median per-cluster mean radius (1 - cos distance from members to their
# centroid) to compute a recommended merge distance. For example:
#
#   median(mean_radius) ≈ 0.17, CLAWSQLITE_INTEREST_MERGE_ALPHA=0.4
#   → suggested merge distance ≈ 0.07
#
# CLAWSQLITE_INTEREST_MERGE_DISTANCE=0.07
# CLAWSQLITE_INTEREST_MERGE_ALPHA=0.4
